# export $(cat .env | xargs)

# Runtime profile
ENVIRONMENT=development
LOG_LEVEL=INFO

# NATS Configuration
NATS_URL=nats://nats:4222

# Crypto symbols (used by both market and token ingestion)
# format: min:full:convert_to
CRYPTO_SYMBOLS=btc:bitcoin:usdc,eth:ethereum:usdc

# Market Ingestion
INGESTION_PLATFORM=polymarket
NATS_SUBJECT_CRYPTO_PRICE_PATTERN=crypto.prices.%s.v1

POLYMARKET_WS_URL=wss://ws-live-data.polymarket.com
BINANCE_WS_URL=wss://fstream.binance.com/stream

# Token Ingestion
NATS_SUBJECT_TOKEN_PRICE_PATTERN=token.prices.%s.v1
NATS_SUBJECT_MARKET_CREATED=market.created.v1
NATS_SUBJECT_MARKET_EXPIRED=market.expired.v1

POLYMARKET_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Market Ingestion
MARKET_DISCOVERY_INTERVAL_SECONDS=10
TOKEN_MARKET_TYPES=5,15,60

POLYMARKET_MARKET_LOOKUP_URL=https://gamma-api.polymarket.com/markets

# Retry WebSocket (market-ingestion + token-ingestion)
WEBSOCKET_RETRY_INITIAL_DELAY=500ms
WEBSOCKET_RETRY_MAX_DELAY=20s
WEBSOCKET_RETRY_MULTIPLIER=1.8

# Retry HTTP (token provider)
HTTP_RETRY_MAX_ATTEMPTS=8
HTTP_RETRY_INITIAL_DELAY=300ms
HTTP_RETRY_MAX_DELAY=6s
HTTP_RETRY_MULTIPLIER=1.8

# WebSocket retry (mais persistente)
#WEBSOCKET_RETRY_INITIAL_DELAY=300ms
#WEBSOCKET_RETRY_MAX_DELAY=45s
#WEBSOCKET_RETRY_MULTIPLIER=1.6

# HTTP retry (mais tentativas, menor delay inicial)
#HTTP_RETRY_MAX_ATTEMPTS=12
#HTTP_RETRY_INITIAL_DELAY=200ms
#HTTP_RETRY_MAX_DELAY=10s
#HTTP_RETRY_MULTIPLIER=1.6
# Price-To-Beat Ingestion
NATS_SUBJECT_PRICE_TO_BEAT_PATTERN=price-to-beat.%s.v1
POLYMARKET_PRICE_TO_BEAT_BOOTSTRAP_URL=https://gamma-api.polymarket.com/markets
# JetStream KV foi escolhido para persistência de estado com baixa latência sem componente extra.
PRICE_TO_BEAT_JETSTREAM_BUCKET=price_to_beat
PRICE_TO_BEAT_RECONCILE_DELAY=2m
PRICE_TO_BEAT_PUBLISH_THRESHOLD_BPS=1
PRICE_TO_BEAT_OPEN_GRACE_PERIOD=20s
